generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name           String?
  username       String?
  title          String?
  image          String?
  profileColor   String?
  profileEmoji   String?
  avatarUrl      String?
  avatarColor    String?
  role           String           @default("member") // "admin" or "member"
  isAssigned     Boolean          @default(true) // false = org member not on this app's plan
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]

  // App-specific relations
  projects       Project[]
  projectMembers ProjectMember[]
  milestones     Milestone[]
  tasks          Task[]
  assignedTasks  Task[]          @relation("assignedTasks")
  subtasks       Subtask[]
  comments       TaskComment[]
  attachments    TaskAttachment[]
  watchers       TaskWatcher[]
  activities     Activity[]
  labels         Label[]
  assignRules    AssignRule[]
  customStatuses CustomStatus[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id            String   @id @default(cuid())
  requestedBy   String
  requestedFor  String   // email of unassigned org member
  status        String   @default("pending") // pending, approved, dismissed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  color       String          @default("#9333ea")
  status      String          @default("active")
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  milestones  Milestone[]
  tasks       Task[]
  members     ProjectMember[]
  labels      Label[]
  statuses    CustomStatus[]
  assignRules AssignRule[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      String   @default("member")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
}

model Milestone {
  id          String    @id @default(cuid())
  name        String
  description String?
  dueDate     DateTime?
  status      String    @default("active")
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      String           @default("todo")
  startDate   DateTime?
  dueDate     DateTime?
  estimate    Float?
  position    Int              @default(0)
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   Milestone?       @relation(fields: [milestoneId], references: [id])
  assigneeId  String?
  assignee    User?            @relation("assignedTasks", fields: [assigneeId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  subtasks    Subtask[]
  comments    TaskComment[]
  labels      TaskLabel[]
  attachments TaskAttachment[]
  watchers    TaskWatcher[]
  activities  Activity[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Label {
  id        String      @id @default(cuid())
  name      String
  color     String
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  tasks     TaskLabel[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model TaskLabel {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId   String
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, labelId])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  path      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskWatcher {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, userId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  detail    String?
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomStatus {
  id        String   @id @default(cuid())
  name      String
  color     String
  position  Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssignRule {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  labelId    String
  assignToId String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
