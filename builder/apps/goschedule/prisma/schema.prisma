generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String?
  profileColor   String?
  profileEmoji   String?
  avatarUrl      String?
  avatarColor    String?
  role           String           @default("member") // "admin" or "member"
  isAssigned     Boolean          @default(true) // false = org member not on this app's plan
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]

  // GoSchedule relations
  provider         Provider?         @relation("staffUser")
  providersCreated Provider[]        @relation("providerCreator")
  services         Service[]
  appointments     Appointment[]
  businessSettings BusinessSettings[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id            String   @id @default(cuid())
  requestedBy   String
  requestedFor  String   // email of unassigned org member
  status        String   @default("pending") // pending, approved, dismissed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model BusinessSettings {
  id                    String   @id @default("singleton")
  businessName          String   @default("My Business")
  logoUrl               String?
  timezone              String   @default("America/New_York")
  bookingPageTitle      String?
  bookingPageColor      String?
  welcomeMessage        String?

  // Stripe
  stripeSecretKey       String?  // encrypted via AES-256-GCM
  stripePublishableKey  String?

  // Notifications
  sendReceipts          Boolean  @default(true)
  sendReminders         Boolean  @default(false)
  reminderTiming        String   @default("24h")

  // Cancellation policy
  cancellationWindow    Int      @default(24)     // hours before appointment
  refundRule            String   @default("full") // "full", "partial", "none"
  partialRefundPercent  Int      @default(50)
  rescheduleWindow      Int      @default(24)     // hours before appointment

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
}

model Service {
  id           String   @id @default(cuid())
  name         String
  description  String?
  durationMin  Int
  price        Float
  currency     String   @default("usd")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  color        String?

  // Custom fields definition as JSON string
  customFields String   @default("[]")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  providers    ProviderService[]
  appointments Appointment[]
}

model Provider {
  id           String   @id @default(cuid())
  staffUserId  String   @unique
  staffUser    User     @relation("staffUser", fields: [staffUserId], references: [id])
  phone        String?
  bio          String?
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation("providerCreator", fields: [userId], references: [id])

  services     ProviderService[]
  availability ProviderAvailability[]
  overrides    ProviderAvailabilityOverride[]
  appointments Appointment[]
}

model ProviderService {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceId])
}

model ProviderAvailability {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0=Sunday .. 6=Saturday
  startTime  String   // "09:00"
  endTime    String   // "17:00"

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([providerId, dayOfWeek])
}

model ProviderAvailabilityOverride {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  date        String   // "2026-03-15"
  isAvailable Boolean  @default(false)
  startTime   String?
  endTime     String?
  reason      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([providerId, date])
}

model BusinessHours {
  id         String   @id @default(cuid())
  dayOfWeek  Int      // 0=Sunday .. 6=Saturday
  isOpen     Boolean  @default(true)
  openTime   String   @default("09:00")  // "HH:mm"
  closeTime  String   @default("17:00")  // "HH:mm"

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([dayOfWeek])
}

model BusinessClosure {
  id        String   @id @default(cuid())
  date      String   // "2026-12-25"
  reason    String?  // "Christmas Day"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
}

model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id              String   @id @default(cuid())

  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id])
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])

  startTime       DateTime
  endTime         DateTime

  status          String   @default("confirmed") // confirmed, completed, no_show, cancelled, rescheduled

  stripePaymentId String?
  amountPaid      Float?
  refundAmount    Float?

  source          String   @default("online") // "online" or "manual"
  manageToken     String   @unique @default(cuid())

  cancelledAt     DateTime?
  cancelReason    String?
  rescheduledFrom String?

  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?  // null for online, set for manual bookings
  user            User?    @relation(fields: [userId], references: [id])

  customFieldValues AppointmentCustomField[]
}

model AppointmentCustomField {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  fieldName     String
  fieldValue    String

  createdAt     DateTime    @default(now())
}
