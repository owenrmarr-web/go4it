generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String? // Profile image from platform (base64)
  profileColor   String? // Hex color for avatar bg (e.g. "#9333EA")
  profileEmoji   String? // Emoji avatar (e.g. "🚀")
  role           String          @default("member") // "admin" or "member"
  isAssigned     Boolean         @default(true) // false = org member not on this app's plan
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]

  // GoWiki relations
  spaces                Space[]
  pages                 Page[]
  pagesByAuthor         Page[]         @relation("PageAuthor")
  pagesByEditor         Page[]         @relation("PageEditor")
  pageRevisionsOwned    PageRevision[]
  pageRevisionsByEditor PageRevision[] @relation("RevisionEditor")
  tags                  Tag[]
  pageTags              PageTag[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id           String   @id @default(cuid())
  requestedBy  String
  requestedFor String // email of unassigned org member
  status       String   @default("pending") // pending, approved, dismissed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model Space {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String   @default("📁")
  color       String   @default("#6366f1")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  pages       Page[]
}

model Page {
  id             String         @id @default(cuid())
  title          String
  slug           String
  content        String
  status         String         @default("DRAFT")
  spaceId        String
  parentId       String?
  authorId       String?
  lastEditedById String?
  viewCount      Int            @default(0)
  pinned         Boolean        @default(false)
  order          Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  space          Space          @relation(fields: [spaceId], references: [id])
  parent         Page?          @relation("PageHierarchy", fields: [parentId], references: [id])
  children       Page[]         @relation("PageHierarchy")
  author         User?          @relation("PageAuthor", fields: [authorId], references: [id])
  lastEditedBy   User?          @relation("PageEditor", fields: [lastEditedById], references: [id])
  revisions      PageRevision[]
  pageTags       PageTag[]

  @@unique([userId, slug])
}

model PageRevision {
  id             String   @id @default(cuid())
  content        String
  changeNotes    String?
  editorId       String?
  revisionNumber Int
  pageId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor         User?    @relation("RevisionEditor", fields: [editorId], references: [id])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#6366f1")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  pageTags  PageTag[]

  @@unique([userId, name])
}

model PageTag {
  id        String   @id @default(cuid())
  pageId    String
  tagId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([pageId, tagId])
}
