generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String?          // Profile image from platform (base64)
  profileColor   String?          // Hex color for avatar bg (e.g. "#9333EA")
  profileEmoji   String?          // Emoji avatar (e.g. "🚀")
  role           String           @default("member") // "admin" or "member"
  isAssigned     Boolean          @default(true) // false = org member not on this app's plan
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests           AccessRequest[]
  departments              Department[]
  departmentHeads          Department[]             @relation("DepartmentHead")
  employeeProfile          EmployeeProfile?
  timeOffRequestsReviewed  TimeOffRequest[]          @relation("TimeOffReviewer")
  documents                Document[]
  announcements            Announcement[]
  onboardingChecklists     OnboardingChecklist[]
  onboardingItems          OnboardingItem[]
  onboardingAssignments    OnboardingAssignment[]
  onboardingItemCompletions OnboardingItemCompletion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id            String   @id @default(cuid())
  requestedBy   String
  requestedFor  String   // email of unassigned org member
  status        String   @default("pending") // pending, approved, dismissed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  headId      String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  head        User?    @relation("DepartmentHead", fields: [headId], references: [id])
  employees   EmployeeProfile[]

  @@unique([name, userId])
}

model EmployeeProfile {
  id             String   @id @default(cuid())
  employeeId     String
  hireDate       DateTime
  jobTitle       String
  employmentType String   @default("FULL_TIME")
  departmentId   String?
  managerId      String?
  phone          String?
  emergencyContact String?
  address        String?
  city           String?
  state          String?
  zip            String?
  hourlyRate     Float?
  salary         Float?
  status         String   @default("ACTIVE")
  terminatedDate DateTime?
  notes          String?
  staffUserId    String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [staffUserId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  timeOffRequests TimeOffRequest[]
  documents      Document[]
  timeEntries    TimeEntry[]
  onboardingAssignments OnboardingAssignment[]
}

model TimeOffRequest {
  id           String    @id @default(cuid())
  type         String
  startDate    DateTime
  endDate      DateTime
  totalDays    Float
  reason       String?
  status       String    @default("PENDING")
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?
  profileId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  profile      EmployeeProfile @relation(fields: [profileId], references: [id])
  reviewedBy   User?     @relation("TimeOffReviewer", fields: [reviewedById], references: [id])
}

model Document {
  id          String    @id @default(cuid())
  title       String
  type        String
  description String?
  fileName    String?
  fileUrl     String?
  expiresAt   DateTime?
  profileId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  profile     EmployeeProfile? @relation(fields: [profileId], references: [id])
}

model TimeEntry {
  id           String    @id @default(cuid())
  date         DateTime
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  totalHours   Float?
  notes        String?
  status       String    @default("PENDING")
  profileId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  profile      EmployeeProfile @relation(fields: [profileId], references: [id])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  priority    String    @default("NORMAL")
  publishDate DateTime  @default(now())
  expiresAt   DateTime?
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id])
}

model OnboardingChecklist {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  items       OnboardingItem[]
  assignments OnboardingAssignment[]
}

model OnboardingItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  checklistId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  completions OnboardingItemCompletion[]
}

model OnboardingAssignment {
  id          String    @id @default(cuid())
  checklistId String
  profileId   String
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id])
  profile     EmployeeProfile @relation(fields: [profileId], references: [id])
  itemCompletions OnboardingItemCompletion[]
}

model OnboardingItemCompletion {
  id           String   @id @default(cuid())
  assignmentId String
  itemId       String
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  assignment   OnboardingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  item         OnboardingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, itemId])
}
