generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String? // Profile image from platform (base64)
  profileColor   String? // Hex color for avatar bg (e.g. "#9333EA")
  profileEmoji   String? // Emoji avatar (e.g. "🚀")
  role           String          @default("member") // "admin" or "member"
  isAssigned     Boolean         @default(true) // false = org member not on this app's plan
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]
  forms          Form[]
  formFields     FormField[]
  submissions    Submission[]
  fieldResponses FieldResponse[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id           String   @id @default(cuid())
  requestedBy  String
  requestedFor String // email of unassigned org member
  status       String   @default("pending") // pending, approved, dismissed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model Form {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  title           String
  description     String?
  type            String       @default("FORM")
  status          String       @default("DRAFT")
  slug            String
  submissionCount Int          @default(0)
  allowMultiple   Boolean      @default(false)
  requireName     Boolean      @default(true)
  requireEmail    Boolean      @default(true)
  closedAt        DateTime?
  closedMessage   String?
  fields          FormField[]
  submissions     Submission[]

  @@unique([userId, slug])
}

model FormField {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  label       String
  type        String
  required    Boolean         @default(false)
  placeholder String?
  options     String?
  order       Int             @default(0)
  formId      String
  form        Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  responses   FieldResponse[]
}

model Submission {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  formId          String
  form            Form            @relation(fields: [formId], references: [id])
  respondentName  String?
  respondentEmail String?
  status          String          @default("COMPLETE")
  notes           String?
  fieldResponses  FieldResponse[]
}

model FieldResponse {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  value        String
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      String
  field        FormField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}
