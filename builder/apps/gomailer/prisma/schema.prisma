generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String? // Profile image from platform (base64)
  profileColor   String? // Hex color for avatar bg (e.g. "#9333EA")
  profileEmoji   String? // Emoji avatar (e.g. "🚀")
  role           String          @default("member") // "admin" or "member"
  isAssigned     Boolean         @default(true) // false = org member not on this app's plan
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]
  contactLists   ContactList[]
  subscribers    Subscriber[]
  templates      Template[]
  campaigns      Campaign[]
  sendLogs       SendLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id           String   @id @default(cuid())
  requestedBy  String
  requestedFor String // email of unassigned org member
  status       String   @default("pending") // pending, approved, dismissed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model ContactList {
  id          String       @id @default(cuid())
  name        String
  description String?
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  subscribers Subscriber[]
  campaigns   Campaign[]
}

model Subscriber {
  id             String      @id @default(cuid())
  email          String
  name           String?
  status         String      @default("ACTIVE")
  subscribedAt   DateTime    @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  listId         String
  list           ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([email, listId])
}

model Template {
  id        String     @id @default(cuid())
  name      String
  subject   String
  body      String
  category  String     @default("GENERAL")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  campaigns Campaign[]
}

model Campaign {
  id             String      @id @default(cuid())
  name           String
  subject        String
  body           String
  status         String      @default("DRAFT")
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int         @default(0)
  openCount      Int         @default(0)
  clickCount     Int         @default(0)
  bounceCount    Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  listId         String
  list           ContactList @relation(fields: [listId], references: [id])
  templateId     String?
  template       Template?   @relation(fields: [templateId], references: [id])
  sendLogs       SendLog[]
}

model SendLog {
  id              String    @id @default(cuid())
  subscriberEmail String
  subscriberName  String?
  status          String    @default("DELIVERED")
  sentAt          DateTime  @default(now())
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
