generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth models (do not remove) ---

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  username       String?
  title          String?
  image          String? // Profile image from platform (base64)
  profileColor   String? // Hex color for avatar bg (e.g. "#9333EA")
  profileEmoji   String? // Emoji avatar (e.g. "🚀")
  role           String          @default("member") // "admin" or "member"
  isAssigned     Boolean         @default(true) // false = org member not on this app's plan
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  accessRequests AccessRequest[]

  // App-specific relations
  folders                  Folder[]
  documents                Document[]
  documentVersionsOwned    DocumentVersion[]  @relation("VersionOwner")
  documentVersionsByAuthor DocumentVersion[]  @relation("VersionAuthor")
  documentCommentsOwned    DocumentComment[]  @relation("CommentOwner")
  documentCommentsByAuthor DocumentComment[]  @relation("DocCommentAuthor")
  documentTemplates        DocumentTemplate[]
  userSettings             UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessRequest {
  id           String   @id @default(cuid())
  requestedBy  String
  requestedFor String // email of unassigned org member
  status       String   @default("pending") // pending, approved, dismissed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [requestedBy], references: [id])
}

// === Add app-specific models below this line ===

model Folder {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String?
  color       String   @default("#6366f1")
  parentId    String?
  userId      String

  user      User       @relation(fields: [userId], references: [id])
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderTree")
  documents Document[]
}

model Document {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  title            String
  type             String    @default("OTHER")
  status           String    @default("DRAFT")
  content          String?
  description      String?
  folderId         String?
  clientName       String?
  clientEmail      String?
  expiresAt        DateTime?
  signedAt         DateTime?
  signedBy         String?
  fileSize         Int?
  fileName         String?
  currentVersionId String?
  userId           String

  user     User              @relation(fields: [userId], references: [id])
  folder   Folder?           @relation(fields: [folderId], references: [id])
  versions DocumentVersion[]
  comments DocumentComment[]
}

model DocumentVersion {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  versionNumber Int
  content       String
  changeNotes   String?
  authorId      String?
  documentId    String
  userId        String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation("VersionAuthor", fields: [authorId], references: [id])
  user     User     @relation("VersionOwner", fields: [userId], references: [id])
}

model DocumentComment {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  content    String
  authorId   String?
  documentId String
  userId     String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation("DocCommentAuthor", fields: [authorId], references: [id])
  user     User     @relation("CommentOwner", fields: [userId], references: [id])
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  type        String   @default("OTHER")
  content     String
  description String?
  userId      String

  user User @relation(fields: [userId], references: [id])
}

model UserSettings {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  userId                String   @unique
  defaultDocumentType   String   @default("OTHER")
  defaultExpirationDays Int      @default(365)
  companyName           String   @default("")
  autoArchiveExpired    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}
